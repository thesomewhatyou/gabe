# required
TOKEN=

# common bot settings
PREFIX=&
OWNER=
LOCALE=en-US
NODE_ENV=production
INVITE_PERMISSIONS=

# database
# empty uses the default sqlite database path
# sqlite:///app/db/gabe.sqlite
# postgres://user:password@host:5432/gabe
DB=

# gif provider
# used to resolve tenor links through klipy's tenor compatible api
KLIPY_API_KEY=

# github and twitter helpers
GITHUB_TOKEN=
NITTER_INSTANCES=

# sentry
SENTRY_DSN=

# discord rest
REST_PROXY=
CLIENT_ID=

# image processing
# local mode is default
# ws mode uses config/servers.json image servers
API_TYPE=
DEBUG=false
TEMPDIR=
TMP_DOMAIN=https://tmp.gabe.net
THRESHOLD=
OUTPUT=

# image api process
PORT=3762
PASS=

# music
STAYVC=false

# pm2 and sharding
PM2_USAGE=
METRICS=
SHARDS=
pm_id=

# runtime and logging
NODE_ARGS=
DEBUG_LOG=

# admin server
ADMIN_SERVER=

# internal values usually set by gabe
ESMBOT_VER=
GIT_REV=
